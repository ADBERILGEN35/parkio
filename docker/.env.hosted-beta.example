# Parkio HOSTED-BETA environment — TEMPLATE for a single VPS.
#
# Copy to `.env` on the VPS (git-ignored) and replace every CHANGE_ME / placeholder:
#     cp .env.hosted-beta.example .env
#
# This is a SUPERSET of .env.example with hosted-beta additions (domains, TLS, public
# media endpoint). It is NOT public-production config (single-broker Kafka RF=1,
# single-node DBs). NEVER commit a real `.env`. NEVER reuse local-dev values here.
#
# Used by:
#   docker compose -f docker-compose.yml -f docker-compose.apps.yml -f docker-compose.hosted-beta.yml up -d --build

# =========================================================================== #
# Hosted-beta: domains & TLS (Caddy)                                           #
# =========================================================================== #
# Public API hostname (Caddy -> gateway-service). DNS A/AAAA -> this VPS.
PARKIO_DOMAIN=api.beta.example.com
# Public SPA hostname (Caddy -> static web app upstream). DNS A/AAAA -> this VPS.
PARKIO_WEB_DOMAIN=app.beta.example.com
# Static SPA upstream reachable from the Caddy container, for example a web container
# serving the Vite build over HTTP.
PARKIO_WEB_UPSTREAM=web:80
# Public media hostname (Caddy -> private MinIO, presigned GETs). DNS A/AAAA -> this VPS.
PARKIO_MEDIA_DOMAIN=media.beta.example.com
# Extra browser connect-src origin for the map basemap (vector tiles). Defaults to
# MapTiler; set to your tile host (or a self-hosted tile server) if you change providers.
PARKIO_MAP_CONNECT_SRC=https://api.maptiler.com
# Extra browser connect-src origin for geocoding. Set to your SLA-backed provider in production.
PARKIO_GEOCODING_CONNECT_SRC=https://nominatim.openstreetmap.org
# ACME registration email (Let's Encrypt expiry/recovery notices).
PARKIO_ACME_EMAIL=ops@example.com
# Max upload size accepted at the proxy for the API site.
PARKIO_MAX_UPLOAD_SIZE=25MB
# Proxy-aware anonymous rate limiting: CIDRs/IPs whose X-Forwarded-For the gateway may trust.
# Set to the Docker bridge / proxy ranges so the gateway derives the REAL client IP for
# anonymous (login/register) buckets instead of Caddy's container IP. NEVER add public ranges
# (that would let anyone spoof their rate-limit identity). Leave unset to trust nothing.
PARKIO_TRUSTED_PROXIES=172.16.0.0/12,10.0.0.0/8,127.0.0.1/32

# =========================================================================== #
# CORS — browser origin(s) of the hosted frontend. Explicit allow-list, NEVER  #
# "*". Set to wherever the SPA is served (its own static host/CDN). If the SPA  #
# is served from the API domain, use https://${PARKIO_DOMAIN}. Comma-separate   #
# multiple origins.                                                            #
# =========================================================================== #
PARKIO_CORS_ALLOWED_ORIGINS=https://app.beta.example.com
PARKIO_CORS_ALLOW_CREDENTIALS=true

# =========================================================================== #
# JWT (RS256). auth-service gets the private key; the gateway validates via JWKS.#
# Generate a PKCS#8 key:  openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# Store as a double-quoted single line with \n escapes. NO production default —  #
# services fail closed if blank. Set audience/issuer explicitly per environment.#
# =========================================================================== #
PARKIO_JWT_PRIVATE_KEY_PEM=
PARKIO_JWT_KEY_ID=parkio-auth-rs256-beta-1
PARKIO_JWT_ISSUER=parkio-auth
PARKIO_JWT_AUDIENCE=parkio-api
PARKIO_JWT_CLOCK_SKEW_SECONDS=30
# JWT key ROTATION (zero-downtime): keep the PREVIOUS public key in the JWKS while old
# access tokens drain. JSON array of {kid, pem} with X.509/SPKI PUBLIC keys (NEVER private).
# Derive a public PEM from the old private key:
#   openssl pkey -in old.pem -pubout
# Signing always uses PARKIO_JWT_KEY_ID above; this only keeps old tokens verifiable until
# they expire (access-token TTL ~15m). Leave blank when no rotation is in progress.
# Example (single line, \n escapes):
#   PARKIO_JWT_ADDITIONAL_PUBLIC_KEYS_JSON=[{"kid":"parkio-auth-rs256-beta-0","pem":"-----BEGIN PUBLIC KEY-----\nMIIBI...\n-----END PUBLIC KEY-----"}]
PARKIO_JWT_ADDITIONAL_PUBLIC_KEYS_JSON=

# =========================================================================== #
# Gateway internal secret (X-Gateway-Auth). Strong random value; same across    #
# all services. No production default — services fail to start if unset.        #
#   generate: openssl rand -base64 48                                           #
# =========================================================================== #
PARKIO_GATEWAY_INTERNAL_SECRET=CHANGE_ME_strong_random_gateway_secret
# Gateway-secret ROTATION (zero-downtime): comma-separated PREVIOUS secret(s) that downstream
# services also accept during the rollover window. The gateway always SENDS only
# PARKIO_GATEWAY_INTERNAL_SECRET; downstream accepts that plus these. Set this on the
# downstream services first, then flip PARKIO_GATEWAY_INTERNAL_SECRET to the new value, then
# clear this once the old secret is fully retired. Leave blank when not rotating.
PARKIO_GATEWAY_INTERNAL_ACCEPTED_SECRETS=

# =========================================================================== #
# Transactional email — required for hosted beta self-service auth flows.      #
# Resend is the current provider; raw tokens must never be logged in hosted     #
# beta/production.                                                             #
# =========================================================================== #
PARKIO_EMAIL_PROVIDER=resend
PARKIO_RESEND_API_KEY=CHANGE_ME_resend_api_key
PARKIO_EMAIL_FROM=Parkio <verify@beta.example.com>
PARKIO_EMAIL_REPLY_TO=support@beta.example.com
PARKIO_EMAIL_VERIFICATION_LOG_TOKEN=false
PARKIO_PASSWORD_RESET_LOG_TOKEN=false

# =========================================================================== #
# Databases — one PostgreSQL per service. Distinct STRONG passwords each.       #
#   generate each: openssl rand -base64 24                                      #
# =========================================================================== #
POSTGRES_AUTH_DB=parkio_auth
POSTGRES_AUTH_USER=parkio_auth
POSTGRES_AUTH_PASSWORD=CHANGE_ME_auth

POSTGRES_USER_DB=parkio_user
POSTGRES_USER_USER=parkio_user
POSTGRES_USER_PASSWORD=CHANGE_ME_user

POSTGRES_PARKING_DB=parkio_parking
POSTGRES_PARKING_USER=parkio_parking
POSTGRES_PARKING_PASSWORD=CHANGE_ME_parking

POSTGRES_MEDIA_DB=parkio_media
POSTGRES_MEDIA_USER=parkio_media
POSTGRES_MEDIA_PASSWORD=CHANGE_ME_media

POSTGRES_GAMIFICATION_DB=parkio_gamification
POSTGRES_GAMIFICATION_USER=parkio_gamification
POSTGRES_GAMIFICATION_PASSWORD=CHANGE_ME_gamification

POSTGRES_NOTIFICATION_DB=parkio_notification
POSTGRES_NOTIFICATION_USER=parkio_notification
POSTGRES_NOTIFICATION_PASSWORD=CHANGE_ME_notification

POSTGRES_MODERATION_DB=parkio_moderation
POSTGRES_MODERATION_USER=parkio_moderation
POSTGRES_MODERATION_PASSWORD=CHANGE_ME_moderation

POSTGRES_ANALYTICS_DB=parkio_analytics
POSTGRES_ANALYTICS_USER=parkio_analytics
POSTGRES_ANALYTICS_PASSWORD=CHANGE_ME_analytics

POSTGRES_AIVALIDATION_DB=parkio_aivalidation
POSTGRES_AIVALIDATION_USER=parkio_aivalidation
POSTGRES_AIVALIDATION_PASSWORD=CHANGE_ME_aivalidation

# NOTE: in the hosted-beta overlay these DB ports are NOT published to the host.
# The POSTGRES_*_PORT vars below are only used by the base file's port mapping,
# which the overlay resets — kept for parity / local use.
POSTGRES_AUTH_PORT=5432
POSTGRES_USER_PORT=5433
POSTGRES_PARKING_PORT=5434
POSTGRES_MEDIA_PORT=5435
POSTGRES_GAMIFICATION_PORT=5436
POSTGRES_NOTIFICATION_PORT=5437
POSTGRES_MODERATION_PORT=5438
POSTGRES_ANALYTICS_PORT=5439
POSTGRES_AIVALIDATION_PORT=5440

# =========================================================================== #
# Redis (private; not published in hosted beta)                               #
# =========================================================================== #
REDIS_PORT=6379

# =========================================================================== #
# Kafka (KRaft, single broker).                                               #
# Generate a cluster id once: docker run --rm confluentinc/cp-kafka:7.7.1 \    #
#   kafka-storage random-uuid                                                  #
# REPLICATION FACTOR: stays 1 on a single-VPS beta (one broker). This is a     #
# known limitation — NOT acceptable for public production, which requires a    #
# managed/HA broker with replication-factor=3 and min.insync.replicas=2.       #
# (The services read PARKIO_KAFKA_REPLICATION_FACTOR; default 1.)              #
# =========================================================================== #
KAFKA_CLUSTER_ID=CHANGE_ME_22_char_base64_uuid
KAFKA_EXTERNAL_PORT=29092
KAFKA_EXPORTER_PORT=9308

# =========================================================================== #
# MinIO (S3-compatible object storage). Private bucket; served via presigned    #
# URLs through Caddy at https://${PARKIO_MEDIA_DOMAIN}.                         #
#   MINIO_ROOT_PASSWORD: openssl rand -base64 24                               #
# =========================================================================== #
MINIO_ROOT_USER=parkio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio
MINIO_BUCKET=parkio-media
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# media-service endpoints:
#  - ENDPOINT: in-cluster SDK ops (PUT/stat/DELETE) -> private MinIO.
#  - PUBLIC_ENDPOINT: host embedded in presigned GET URLs -> MUST equal the public
#    media host the browser uses. SigV4 signs the Host header, so this has to match
#    https://${PARKIO_MEDIA_DOMAIN} exactly (set the literal value below).
PARKIO_MEDIA_STORAGE_ENDPOINT=http://minio:9000
PARKIO_MEDIA_STORAGE_PUBLIC_ENDPOINT=https://media.beta.example.com

# =========================================================================== #
# ClamAV — anti-malware scan for media uploads (REQUIRED in hosted beta).       #
# media-service scans bytes via clamd before storing/serving and FAILS CLOSED   #
# (503) if clamd is unreachable. The clamav service stays private (no host      #
# port). Leave ENABLED=true; disabling it serves unscanned uploads.             #
# =========================================================================== #
PARKIO_MEDIA_SCANNER_ENABLED=true
PARKIO_MEDIA_SCANNER_HOST=clamav
PARKIO_MEDIA_SCANNER_PORT=3310
PARKIO_MEDIA_SCANNER_CONNECT_TIMEOUT=2s
PARKIO_MEDIA_SCANNER_READ_TIMEOUT=10s

# =========================================================================== #
# Observability (loopback-only on the VPS in hosted beta; reach via SSH tunnel) #
#   GRAFANA_ADMIN_PASSWORD: openssl rand -base64 24                            #
# =========================================================================== #
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
LOKI_PORT=3100
PROMTAIL_PORT=9080
# Tempo trace-query/admin API — loopback-only on the VPS (SSH tunnel -L 3200:localhost:3200).
# The OTLP receivers (4317/4318) are never published; services reach them in-network only.
TEMPO_PORT=3200
PARKIO_ENVIRONMENT=hosted-beta
# 168h = 7 days. Increase only with enough VPS disk headroom.
PARKIO_LOKI_RETENTION_PERIOD=168h
# Distributed tracing (OpenTelemetry -> Tempo). Hosted-beta runs 100% sampling so every
# request is traceable; drop to 0.05-0.20 if trace volume/disk becomes a concern. The OTLP
# endpoint stays the private in-network Tempo receiver. Trace retention defaults to 48h.
PARKIO_TRACING_ENABLED=true
PARKIO_TRACING_SAMPLING_PROBABILITY=1.0
PARKIO_TRACING_OTLP_ENDPOINT=http://tempo:4318/v1/traces
PARKIO_TEMPO_RETENTION=48h
# Alert delivery. Slack is the hosted-beta default receiver; leave the webhook
# blank only if you intentionally want alerts visible in Alertmanager without
# outbound notification. Never commit the real webhook URL.
PARKIO_ALERT_SLACK_WEBHOOK_URL=CHANGE_ME_slack_webhook_url
PARKIO_ALERT_SLACK_CHANNEL="#parkio-alerts"
PARKIO_ALERT_REPEAT_CRITICAL=1h
PARKIO_ALERT_REPEAT_WARNING=4h
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana

# =========================================================================== #
# JVM / runtime                                                               #
# =========================================================================== #
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0

# =========================================================================== #
# Backups (used by scripts/backup-databases.sh) — optional remote upload.      #
# Leave BACKUP_MC_DEST blank to keep backups in the local BACKUP_DIR only.      #
# =========================================================================== #
BACKUP_DIR=/var/backups/parkio
# Encrypt each dump at rest with AES-256 (recommended if uploading off-box).
BACKUP_ENCRYPT_PASSPHRASE=
# Remote object-storage target via MinIO client `mc` alias (e.g. s3/parkio-backups).
# Configure the alias on the host first: mc alias set <name> <endpoint> <key> <secret>
BACKUP_MC_DEST=
# How many daily backup folders to keep locally.
BACKUP_RETENTION_DAYS=14
