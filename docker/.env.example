# Parkio local development environment — TEMPLATE.
#
# Copy to `.env` (which is git-ignored) and adjust as needed:
#     cp .env.example .env
#
# These are LOCAL DEVELOPMENT defaults. Never commit a real `.env`, and never
# reuse these values outside local dev (ai-context/07: secrets stay out of git).

# --------------------------------------------------------------------------- #
# Image versions (override to pin/upgrade without editing compose files)      #
# --------------------------------------------------------------------------- #
POSTGRES_IMAGE=postgres:16-alpine
POSTGIS_IMAGE=postgis/postgis:16-3.4
REDIS_IMAGE=redis:7-alpine
KAFKA_IMAGE=confluentinc/cp-kafka:7.7.1
MINIO_IMAGE=minio/minio:RELEASE.2024-09-13T20-26-02Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2024-09-16T17-43-14Z
PROMETHEUS_IMAGE=prom/prometheus:v2.54.1
GRAFANA_IMAGE=grafana/grafana:11.2.0

# --------------------------------------------------------------------------- #
# Databases — one PostgreSQL instance per service (database-per-service).      #
# Distinct credentials per service follow least-privilege (ai-context/07).     #
# CHANGE every password below before sharing your environment.                 #
# --------------------------------------------------------------------------- #

# auth-service
POSTGRES_AUTH_DB=parkio_auth
POSTGRES_AUTH_USER=parkio_auth
POSTGRES_AUTH_PASSWORD=auth_local_dev_pw
POSTGRES_AUTH_PORT=5432

# user-service
POSTGRES_USER_DB=parkio_user
POSTGRES_USER_USER=parkio_user
POSTGRES_USER_PASSWORD=user_local_dev_pw
POSTGRES_USER_PORT=5433

# parking-service (PostGIS)
POSTGRES_PARKING_DB=parkio_parking
POSTGRES_PARKING_USER=parkio_parking
POSTGRES_PARKING_PASSWORD=parking_local_dev_pw
POSTGRES_PARKING_PORT=5434

# media-service
POSTGRES_MEDIA_DB=parkio_media
POSTGRES_MEDIA_USER=parkio_media
POSTGRES_MEDIA_PASSWORD=media_local_dev_pw
POSTGRES_MEDIA_PORT=5435

# gamification-service
POSTGRES_GAMIFICATION_DB=parkio_gamification
POSTGRES_GAMIFICATION_USER=parkio_gamification
POSTGRES_GAMIFICATION_PASSWORD=gamification_local_dev_pw
POSTGRES_GAMIFICATION_PORT=5436

# notification-service
POSTGRES_NOTIFICATION_DB=parkio_notification
POSTGRES_NOTIFICATION_USER=parkio_notification
POSTGRES_NOTIFICATION_PASSWORD=notification_local_dev_pw
POSTGRES_NOTIFICATION_PORT=5437

# moderation-service
POSTGRES_MODERATION_DB=parkio_moderation
POSTGRES_MODERATION_USER=parkio_moderation
POSTGRES_MODERATION_PASSWORD=moderation_local_dev_pw
POSTGRES_MODERATION_PORT=5438

# analytics-service
POSTGRES_ANALYTICS_DB=parkio_analytics
POSTGRES_ANALYTICS_USER=parkio_analytics
POSTGRES_ANALYTICS_PASSWORD=analytics_local_dev_pw
POSTGRES_ANALYTICS_PORT=5439

# ai-validation-service
POSTGRES_AIVALIDATION_DB=parkio_aivalidation
POSTGRES_AIVALIDATION_USER=parkio_aivalidation
POSTGRES_AIVALIDATION_PASSWORD=aivalidation_local_dev_pw
POSTGRES_AIVALIDATION_PORT=5440

# --------------------------------------------------------------------------- #
# Redis                                                                       #
# --------------------------------------------------------------------------- #
REDIS_PORT=6379

# --------------------------------------------------------------------------- #
# Kafka (KRaft mode)                                                          #
# CLUSTER_ID must be a 22-char base64 UUID. Generate one with:                 #
#   docker run --rm confluentinc/cp-kafka:7.7.1 kafka-storage random-uuid      #
# --------------------------------------------------------------------------- #
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_EXTERNAL_PORT=29092

# --------------------------------------------------------------------------- #
# MinIO (S3-compatible object storage)                                        #
# --------------------------------------------------------------------------- #
MINIO_ROOT_USER=parkio
MINIO_ROOT_PASSWORD=minio_local_dev_pw
MINIO_BUCKET=parkio-media
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# media-service MinIO endpoints (split for SigV4 presigned GET URLs):
# - endpoint: in-cluster / container-reachable (SDK PUT, stat, DELETE)
# - public-endpoint: host embedded in presigned GET URLs (must match the browser)
# SigV4 signs the Host header (X-Amz-SignedHeaders=host); the URL host cannot be
# changed after signing. Override per environment; never commit a production URL.
PARKIO_MEDIA_STORAGE_ENDPOINT=http://minio:9000
PARKIO_MEDIA_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000

# --------------------------------------------------------------------------- #
# Observability                                                               #
# --------------------------------------------------------------------------- #
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_local_dev_pw

# --------------------------------------------------------------------------- #
# Application services (only used with docker-compose.apps.yml)               #
# --------------------------------------------------------------------------- #
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0

# Gateway-only ingress shared secret (ai-context/07). The gateway injects this as the
# X-Gateway-Auth header on every routed request; every downstream service requires it,
# so a directly-reachable service cannot be called without going through the gateway.
# LOCAL-DEV VALUE ONLY — generate a strong random secret per real environment and never
# commit it. There is no production default: services fail to start if it is unset.
PARKIO_GATEWAY_INTERNAL_SECRET=local-dev-only-gateway-internal-secret-change-me

# RS256 access-token signing. auth-service receives the private key; gateway-service
# receives only the JWKS URL. Generate a local PKCS#8 key with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# Store the PEM as a quoted value with \n escapes in the real, git-ignored `.env`.
# This template intentionally contains no private key.
PARKIO_JWT_PRIVATE_KEY_PEM=
PARKIO_JWT_KEY_ID=parkio-auth-rs256-1
PARKIO_JWT_ISSUER=parkio-auth
# Audience (aud claim): stamped by auth-service, validated by the gateway. Must be the
# SAME value on both. `parkio-api` is the dev default; set explicitly per environment.
PARKIO_JWT_AUDIENCE=parkio-api
# Tolerance (seconds) for exp/nbf validation at the gateway to absorb clock drift.
PARKIO_JWT_CLOCK_SKEW_SECONDS=30

# Browser origins allowed to call the gateway (CORS). Explicit allow-list — NEVER "*".
# Defaults to the local Vite dev server so a local frontend can call the API. Use a
# comma-separated list for multiple origins; set the real web origin(s) in production.
# Empty (the application.yml default) denies all cross-origin browser access.
PARKIO_CORS_ALLOWED_ORIGINS=http://localhost:5173
PARKIO_CORS_ALLOW_CREDENTIALS=true
