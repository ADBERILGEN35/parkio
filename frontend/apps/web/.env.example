# Gateway base URL — the ONLY API entrypoint. Never point at service ports (8081–8089).
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_ENV=development

# Client-side error reporting. Disabled by default; set to `console` only for
# hosted diagnostics until a provider adapter (Sentry/OTel/etc.) is added.
VITE_FRONTEND_ERROR_REPORTING=disabled

# Map basemap (MapLibre GL). Provide a MapTiler key for production-grade vector
# tiles (HiDPI/Retina, vector typography, dark-mode-ready). Get a free key at
# https://cloud.maptiler.com/account/keys/ . NEVER hardcode the key in source —
# it is injected here at build time. If unset, the map falls back to OpenStreetMap
# raster tiles automatically (fine for local/dev), so the map always works.
# VITE_MAPTILER_KEY=your_maptiler_key
# VITE_MAPTILER_STYLE=streets-v2

# Raster fallback overrides (used ONLY when VITE_MAPTILER_KEY is not set).
# VITE_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# VITE_MAP_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors

# Forward geocoding (address/place -> lat/lng) for /map search. Defaults to the
# public OpenStreetMap Nominatim endpoint, which is suitable for local beta only.
# For production, point this at the backend or a provider with an SLA/key.
# VITE_GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
